# Dependencies
node_modules/

# Secrets / local env — only .env.example is committed
.env
.env.*
!.env.example

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
ios/
android/

# Firebase Android config (carries a Google API key — fed to the build via an EAS
# file env var, never committed; see app.config.js + the GOOGLE_SERVICES_JSON env var).
google-services.json

# MCP — project-scoped server config (no secret, but not committed)
.mcp.json

# Logs & misc
*.log
npm-debug.*
coverage/
.DS_Store
