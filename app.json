{
  "expo": {
    "name": "Gym-App",
    "slug": "gym-app",
    "scheme": "gymapp",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "android": {
      "package": "com.mo2adev.gymapp"
    },
    "ios": {
      "bundleIdentifier": "com.mo2adev.gymapp"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can upload progress photos and InBody scans.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to use the camera so you can capture progress photos and InBody scans."
        }
      ],
      "expo-localization",
      "expo-notifications",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone so you can send voice notes in chat."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5ddd6ee-80ec-4a11-8048-18af107ca1d1"
      }
    },
    "owner": "mo2adev"
  }
}
