{
  "name": "gym-app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "db:local": "bash scripts/db-local.sh",
    "db:apply": "bash scripts/db-apply.sh",
    "test:rls": "tsx supabase/tests/rls/runner.ts",
    "test": "npm run test:rls",
    "typecheck": "tsc --noEmit",
    "lint:secrets": "gitleaks detect --config .gitleaks.toml --redact",
    "prepare": "bash scripts/install-hooks.sh || true"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@supabase/supabase-js": "^2.108.2",
    "@types/react": "~19.1.10",
    "expo": "^54.0.35",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3"
  }
}
