#!/usr/bin/env bash
# Block commits that contain secrets (CLAUDE.md §3). CI enforces this too.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks not installed — skipping local secret scan (CI still enforces it)."
  echo "Install gitleaks to scan before committing: https://github.com/gitleaks/gitleaks"
  exit 0
fi

gitleaks protect --staged --redact --config .gitleaks.toml
